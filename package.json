{
	"name": "antiox",
	"version": "0.1.0",
	"description": "I Wish I Was Writing Rust. Small utilities for Rust/Tokio-like primitives in TypeScript.",
	"license": "MIT",
	"type": "module",
	"files": [
		"dist",
		"src",
		"package.json"
	],
	"exports": {
		".": {
			"import": { "types": "./dist/mod.d.ts", "default": "./dist/mod.js" },
			"require": { "types": "./dist/mod.d.cts", "default": "./dist/mod.cjs" }
		},
		"./panic": {
			"import": { "types": "./dist/panic.d.ts", "default": "./dist/panic.js" },
			"require": { "types": "./dist/panic.d.cts", "default": "./dist/panic.cjs" }
		},
		"./sync/mpsc": {
			"import": { "types": "./dist/sync/mpsc.d.ts", "default": "./dist/sync/mpsc.js" },
			"require": { "types": "./dist/sync/mpsc.d.cts", "default": "./dist/sync/mpsc.cjs" }
		},
		"./sync/oneshot": {
			"import": { "types": "./dist/sync/oneshot.d.ts", "default": "./dist/sync/oneshot.js" },
			"require": { "types": "./dist/sync/oneshot.d.cts", "default": "./dist/sync/oneshot.cjs" }
		},
		"./sync/watch": {
			"import": { "types": "./dist/sync/watch.d.ts", "default": "./dist/sync/watch.js" },
			"require": { "types": "./dist/sync/watch.d.cts", "default": "./dist/sync/watch.cjs" }
		},
		"./sync/broadcast": {
			"import": { "types": "./dist/sync/broadcast.d.ts", "default": "./dist/sync/broadcast.js" },
			"require": { "types": "./dist/sync/broadcast.d.cts", "default": "./dist/sync/broadcast.cjs" }
		},
		"./sync/semaphore": {
			"import": { "types": "./dist/sync/semaphore.d.ts", "default": "./dist/sync/semaphore.js" },
			"require": { "types": "./dist/sync/semaphore.d.cts", "default": "./dist/sync/semaphore.cjs" }
		},
		"./sync/notify": {
			"import": { "types": "./dist/sync/notify.d.ts", "default": "./dist/sync/notify.js" },
			"require": { "types": "./dist/sync/notify.d.cts", "default": "./dist/sync/notify.cjs" }
		},
		"./sync/mutex": {
			"import": { "types": "./dist/sync/mutex.d.ts", "default": "./dist/sync/mutex.js" },
			"require": { "types": "./dist/sync/mutex.d.cts", "default": "./dist/sync/mutex.cjs" }
		},
		"./sync/rwlock": {
			"import": { "types": "./dist/sync/rwlock.d.ts", "default": "./dist/sync/rwlock.js" },
			"require": { "types": "./dist/sync/rwlock.d.cts", "default": "./dist/sync/rwlock.cjs" }
		},
		"./sync/barrier": {
			"import": { "types": "./dist/sync/barrier.d.ts", "default": "./dist/sync/barrier.js" },
			"require": { "types": "./dist/sync/barrier.d.cts", "default": "./dist/sync/barrier.cjs" }
		},
		"./sync/select": {
			"import": { "types": "./dist/sync/select.d.ts", "default": "./dist/sync/select.js" },
			"require": { "types": "./dist/sync/select.d.cts", "default": "./dist/sync/select.cjs" }
		},
		"./task": {
			"import": { "types": "./dist/task.d.ts", "default": "./dist/task.js" },
			"require": { "types": "./dist/task.d.cts", "default": "./dist/task.cjs" }
		},
		"./time": {
			"import": { "types": "./dist/time.d.ts", "default": "./dist/time.js" },
			"require": { "types": "./dist/time.d.cts", "default": "./dist/time.cjs" }
		},
		"./stream": {
			"import": { "types": "./dist/stream.d.ts", "default": "./dist/stream.js" },
			"require": { "types": "./dist/stream.d.cts", "default": "./dist/stream.cjs" }
		}
	},
	"scripts": {
		"build": "tsup",
		"check-types": "tsc --noEmit",
		"test": "vitest run",
		"bundle-size": "tsx scripts/bundle-size.ts"
	},
	"devDependencies": {
		"@types/node": "^22.13.1",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^4.1.2"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/rivet-dev/antiox.git"
	}
}
